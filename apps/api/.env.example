# ══════════════════════════════════════════════════════════════
# ClienteBox API — variáveis de ambiente
# Copie para .env e preencha os valores antes de iniciar
# ══════════════════════════════════════════════════════════════

# ─── Servidor ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3333

# ─── Banco de dados (PostgreSQL) ──────────────────────────────
# Usuário/senha/banco padrão definidos no docker-compose.yml
DATABASE_URL=postgresql://clientebox:clientebox123@localhost:5433/clientebox_dev

# ─── JWT (mude o segredo em produção!) ───────────────────────
JWT_SECRET=troque-esta-chave-em-producao-123
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────────
# Deixe em branco para aceitar qualquer origem (desenvolvimento)
# Em produção: ALLOWED_ORIGIN=https://seudominio.com
# ALLOWED_ORIGIN=
