{
  "name": "@clientebox/api",
  "version": "1.0.0",
  "description": "Back-end API do ClienteBox — Fastify + Prisma + TypeScript",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "postinstall": "prisma generate",
    "prebuild": "npm run build -w @clientebox/shared",
    "build": "tsc",
    "prestart": "prisma migrate deploy && npx tsx prisma/seed-if-empty.ts",
    "start": "node dist/server.js",
    "lint": "eslint src/ --ext .ts",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "dependencies": {
    "@clientebox/shared": "*",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "@fastify/swagger": "^8.0.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.26.0",
    "ms": "^2.1.3",
    "winston": "^3.11.0",
    "prisma": "^5.10.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/ms": "^0.7.34",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
