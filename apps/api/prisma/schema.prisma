generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── AUTENTICAÇÃO ────────────────────────────────────────────

model Usuario {
  id                  String   @id @default(uuid())
  nome                String
  email               String   @unique
  senhaHash           String   @map("senha_hash")
  ativo               Boolean  @default(true)
  onboardingConcluido Boolean  @default(false) @map("onboarding_concluido")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  clientes      Cliente[]
  interacoes    Interacao[]
  oportunidades Oportunidade[]
  categorias    Categoria[]
  lancamentos   Lancamento[]
  produtos      Produto[]
  metas         Meta[]
  logsAuditoria LogAuditoria[]

  @@map("usuarios")
}

// Refresh token opaco (não é JWT): só o hash SHA-256 é persistido.
// Rotacionado a cada uso, com detecção de reuso (token já revogado
// sendo reapresentado revoga todas as sessões do usuário).
model RefreshToken {
  id                  String    @id @default(uuid())
  usuarioId           String    @map("usuario_id")
  tokenHash           String    @unique @map("token_hash")
  expiresAt           DateTime  @map("expires_at")
  revokedAt           DateTime? @map("revoked_at")
  replacedByTokenHash String?   @map("replaced_by_token_hash")
  userAgent           String?   @map("user_agent")
  ip                  String?
  createdAt           DateTime  @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─── CRM ─────────────────────────────────────────────────────

model Cliente {
  id          String   @id @default(uuid())
  usuarioId   String   @map("usuario_id")
  nome        String
  email       String?
  telefone    String?
  cpfCnpj     String?  @map("cpf_cnpj")
  cep         String?
  endereco    String?
  cidade      String?
  estado      String?  @db.VarChar(2)
  dataNascimento DateTime? @map("data_nascimento")
  status      String   @default("ativo") // ativo | inativo
  tags        String[] @default([])
  observacoes String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  usuario       Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  interacoes    Interacao[]
  oportunidades Oportunidade[]
  lancamentos   Lancamento[]

  @@index([usuarioId])
  @@map("clientes")
}

model Interacao {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  clienteId String   @map("cliente_id")
  tipo      String // whatsapp | ligacao | email | visita | venda | orcamento | outro
  descricao String
  data      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([clienteId])
  @@map("interacoes")
}

model Oportunidade {
  id             String    @id @default(uuid())
  usuarioId      String    @map("usuario_id")
  clienteId      String    @map("cliente_id")
  titulo         String
  descricao      String?
  valorEstimado  Decimal   @default(0) @db.Decimal(12, 2) @map("valor_estimado")
  etapa          String    @default("contato") // contato | negociacao | proposta | fechado_ganho | fechado_perdido
  posicao        Int       @default(0)
  motivoPerda    String?   @map("motivo_perda")
  dataFechamento DateTime? @map("data_fechamento")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([clienteId])
  @@index([etapa])
  @@map("oportunidades")
}

// ─── FINANCEIRO ──────────────────────────────────────────────

model Categoria {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  nome      String
  tipo      String // receita | despesa
  cor       String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  lancamentos Lancamento[]
  produtos    Produto[]

  @@unique([usuarioId, nome, tipo])
  @@index([usuarioId])
  @@map("categorias")
}

model Produto {
  id          String   @id @default(uuid())
  usuarioId   String   @map("usuario_id")
  nome        String
  preco       Decimal  @db.Decimal(12, 2)
  categoriaId String?  @map("categoria_id")
  descricao   String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  usuario     Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria   Categoria?   @relation(fields: [categoriaId], references: [id])
  lancamentos Lancamento[]

  @@unique([usuarioId, nome])
  @@index([usuarioId])
  @@map("produtos")
}

model Lancamento {
  id             String    @id @default(uuid())
  usuarioId      String    @map("usuario_id")
  categoriaId    String?   @map("categoria_id")
  clienteId      String?   @map("cliente_id")
  produtoId      String?   @map("produto_id")
  tipo           String // receita | despesa
  descricao      String
  valor          Decimal   @db.Decimal(12, 2)
  data           DateTime  @default(now())
  dataVencimento DateTime? @map("data_vencimento")
  dataPagamento  DateTime? @map("data_pagamento")
  status         String    @default("pendente") // pendente | pago | vencido | cancelado
  formaPagamento String?   @map("forma_pagamento") // dinheiro|pix|cartao_debito|cartao_credito|boleto|transferencia|outro
  recorrente     Boolean   @default(false)
  observacoes    String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // Lançamento-modelo tem recorrente=true e recorrenciaOrigemId=null; cada
  // ocorrência gerada automaticamente aponta pro modelo que a originou.
  recorrenciaOrigemId String?      @map("recorrencia_origem_id")
  recorrenciaOrigem   Lancamento?  @relation("Recorrencia", fields: [recorrenciaOrigemId], references: [id])
  geracoesRecorrentes Lancamento[] @relation("Recorrencia")

  usuario   Usuario    @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria Categoria? @relation(fields: [categoriaId], references: [id])
  cliente   Cliente?   @relation(fields: [clienteId], references: [id])
  produto   Produto?   @relation(fields: [produtoId], references: [id])

  @@index([usuarioId])
  @@index([recorrenciaOrigemId])
  @@index([categoriaId])
  @@index([produtoId])
  @@index([status])
  @@index([dataVencimento])
  @@map("lancamentos")
}

model Meta {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  mes       DateTime // dia 1 do mês de referência
  valorMeta Decimal  @db.Decimal(12, 2) @map("valor_meta")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, mes])
  @@index([usuarioId])
  @@map("metas")
}

model LogAuditoria {
  id         String   @id @default(uuid())
  usuarioId  String   @map("usuario_id")
  acao       String // criar | atualizar | status | mover
  entidade   String // cliente | lancamento | oportunidade | categoria | produto | meta
  entidadeId String?  @map("entidade_id")
  descricao  String
  createdAt  DateTime @default(now()) @map("created_at")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, createdAt])
  @@map("logs_auditoria")
}
